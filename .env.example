# Weaviate Configuration
WEAVIATE_URL=http://localhost:8090
WEAVIATE_GRPC_URL=localhost:50061
WEAVIATE_IS_LOCAL=True

# SKOSMOS Configuration (vocabulary lookup service)
SKOSMOS_URL=http://localhost:8080

# LLM Provider Configuration
# Options: "ollama" (local), "github_models" (free, 8K token limit), "openai" (pay-per-use)
LLM_PROVIDER=ollama

# --- Ollama (Local) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b  # Alternative: qwen3:14b, smollm3 (lighter)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe

# --- GitHub Models (Alliander Enterprise) ---
# GITHUB_MODELS_API_KEY=github_pat_your_token_here
# GITHUB_MODELS_MODEL=openai/gpt-4.1

# --- GitHub Models (Non-Alliander/personal) ---
# GITHUB_MODELS_API_KEY=ghp_your_token_here
# GITHUB_MODELS_MODEL=openai/gpt-4.1

# --- OpenAI (Pay-per-token, requires sk- key) ---
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_CHAT_MODEL=gpt-5.2

# GitHub Token (optional - for private repos)
# GITHUB_TOKEN=ghp_your_github_token_here

# Data paths (relative to project root)
DATA_PATH=./data
MARKDOWN_PATH=./data/esa-main-artifacts/doc
POLICY_PATH=./data/do-artifacts/policy_docs
PRINCIPLES_PATH=./data/esa-main-artifacts/doc/principles

# Logging
LOG_LEVEL=INFO
FIRST_START_ELYSIA='1'
FERNET_KEY='generate-your-own-fernet-key-here'
