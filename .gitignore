# Plugin deployment directory: only the bundled plugins are committed —
# ainstein-kernel (kernel), esa-workflow (ESA domain),
# enterpower-architecture (authoritative architecture domain; superseded
# the former transitional ainstein-core). Other operator-deployed plugins
# live here at runtime but are NOT tracked.
plugins/*
!plugins/ainstein-kernel/
!plugins/ainstein-kernel/**
!plugins/esa-workflow/
!plugins/esa-workflow/**
!plugins/enterpower-architecture/
!plugins/enterpower-architecture/**
# The ** re-includes above override the global .DS_Store / *.bak rules
# inside the tracked plugins — re-assert them so editor/Finder junk and
# skills-API backup files never get committed under any bundled plugin.
plugins/ainstein-kernel/**/.DS_Store
plugins/ainstein-kernel/**/*.bak
plugins/ainstein-kernel/**/*.bak.*
plugins/esa-workflow/**/.DS_Store
plugins/esa-workflow/**/*.bak
plugins/esa-workflow/**/*.bak.*
plugins/enterpower-architecture/**/.DS_Store
plugins/enterpower-architecture/**/*.bak
plugins/enterpower-architecture/**/*.bak.*
# enterpower's node_modules / build output must never be committed.
plugins/enterpower-architecture/**/node_modules/
plugins/enterpower-architecture/mcp/visual-preview/dist/
plugins/enterpower-architecture/templates/*/node_modules/
